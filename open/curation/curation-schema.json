{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renewcanvas.example/open/curation/curation-schema.json",
  "title": "RenewCanvas Museum Curation API Schemas",
  "$defs": {
    "artworkCategory": {
      "enum": ["Wall Art", "Sculpture", "Home Decor", "Jewelry", "Functional Art", "Mixed Media", "Installation", "Other"]
    },
    "recyclableMaterial": {
      "enum": ["PET bottles", "Bottle caps", "Cardboard", "Paper", "Fabric scraps", "Aluminium cans", "Glass", "Electronic waste", "Burlap/grain sacks", "Plastic bags", "Metal scraps", "Other"]
    },
    "curationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artworks"],
      "properties": {
        "artworks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 500,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "artistName", "category", "materials"],
            "properties": {
              "id": { "type": "string", "minLength": 1, "maxLength": 120 },
              "title": { "type": "string", "minLength": 1, "maxLength": 180 },
              "artistName": { "type": "string", "minLength": 1, "maxLength": 180 },
              "category": { "$ref": "#/$defs/artworkCategory" },
              "materials": {
                "type": "array",
                "minItems": 1,
                "maxItems": 12,
                "items": { "$ref": "#/$defs/recyclableMaterial" }
              },
              "imageUrl": {
                "maxLength": 500,
                "description": "Must be http(s) or site-relative. Protocol-relative URLs are rejected.",
                "anyOf": [
                  { "type": "string", "format": "uri", "pattern": "^https?://" },
                  { "type": "string", "pattern": "^/(?!/)" }
                ]
              },
              "colorPalette": { "type": "array", "maxItems": 8, "items": { "type": "string", "maxLength": 32 } },
              "mlTags": { "type": "array", "maxItems": 24, "items": { "type": "string", "maxLength": 48 } },
              "artistLocation": { "type": "string", "maxLength": 120 },
              "impactScore": { "type": "number", "minimum": 0, "maximum": 100 },
              "kgDiverted": { "type": "number", "minimum": 0, "maximum": 500 }
            }
          }
        }
      }
    },
    "curationResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan", "requestId"],
      "properties": {
        "requestId": { "type": "string" },
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seed", "totalArtworks", "rooms", "placements", "accessibilitySummary"],
          "properties": {
            "seed": { "type": "string" },
            "totalArtworks": { "type": "integer", "minimum": 1, "maximum": 500 },
            "accessibilitySummary": { "type": "string" },
            "rooms": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "wingIndex", "roomIndex", "title", "roomKind", "grouping", "groupingValue", "capacity", "accessibilityLabel"],
                "properties": {
                  "id": { "type": "string" },
                  "wingIndex": { "type": "integer", "minimum": 0 },
                  "roomIndex": { "type": "integer", "minimum": 0 },
                  "title": { "type": "string" },
                  "roomKind": { "enum": ["main_gallery", "side_gallery", "court", "cabinet"] },
                  "grouping": { "enum": ["type", "material", "impact", "mixed"] },
                  "groupingValue": { "type": "string" },
                  "capacity": { "type": "integer", "minimum": 1 },
                  "accessibilityLabel": { "type": "string" }
                }
              }
            },
            "placements": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["artworkId", "roomId", "wingIndex", "slotIndex", "wallSide", "arrangementExplanation"],
                "properties": {
                  "artworkId": { "type": "string" },
                  "roomId": { "type": "string" },
                  "wingIndex": { "type": "integer", "minimum": 0 },
                  "slotIndex": { "type": "integer", "minimum": 0 },
                  "wallSide": { "enum": ["north", "south", "east", "west", "floor"] },
                  "arrangementExplanation": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/curationRequest" },
    { "$ref": "#/$defs/curationResponse" }
  ]
}
