{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RenewCanvas Impact Estimator Request",
  "type": "object",
  "required": ["materials"],
  "properties": {
    "materials": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["type", "weightKg", "verifiedByImage"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "PET bottles",
              "Bottle caps",
              "Cardboard",
              "Paper",
              "Fabric scraps",
              "Aluminium cans",
              "Glass",
              "Electronic waste",
              "Burlap/grain sacks",
              "Plastic bags",
              "Metal scraps",
              "Other"
            ]
          },
          "weightKg": {
            "type": "number",
            "minimum": 0.001,
            "maximum": 250
          },
          "verifiedByImage": { "type": "boolean" },
          "confidenceScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
