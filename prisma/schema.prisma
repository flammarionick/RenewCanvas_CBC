generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  buyer
  artist
  admin
}

enum AccountStatus {
  active
  pending_verification
  suspended
  deleted
}

enum ArtworkStatus {
  draft
  submitted
  under_review
  approved
  rejected
  listed
  reserved
  sold
  archived
}

enum ArtworkOwnerType {
  artist
  renewcanvas
}

enum MediaUploadStatus {
  pending
  uploaded
  failed
}

enum OrderStatus {
  pending_payment
  paid
  processing
  shipped
  delivered
  cancelled
  refunded
  failed
}

enum CommissionRequestStatus {
  submitted
  assigned
  accepted
  rejected
  cancelled
  completed
}

enum CommissionSizeCategory {
  small
  medium
  large
  custom
}

enum VerificationReviewStatus {
  pending
  approved
  rejected
  more_info_requested
}

enum VerificationEvidenceType {
  material_photo
  process_photo
  identity_document
  note
  other
}

enum PaymentProvider {
  mtn_momo
  manual_bank
}

enum PaymentStatus {
  requires_action
  pending
  paid
  failed
  cancelled
  refunded
}

enum ShipmentStatus {
  pending
  preparing
  ready_for_pickup
  in_transit
  delivered
  failed
  returned
}

enum PayoutStatus {
  pending
  eligible
  approved
  paid
  failed
  cancelled
}

enum NotificationChannel {
  email
  sms
  whatsapp
  in_app
}

enum NotificationStatus {
  queued
  sent
  failed
  skipped
}

enum AuctionStatus {
  draft
  scheduled
  live
  ended
  cancelled
  settled
}

enum BidStatus {
  active
  outbid
  winning
  rejected
  cancelled
}

enum ReturnRequestStatus {
  open
  approved
  rejected
  closed
}

enum ContactMessageType {
  contact_form
  artist_application
  partnership_inquiry
  waste_supply_request
}

enum ContactMessageStatus {
  unread
  read
  replied
  archived
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  role         UserRole
  status       AccountStatus @default(active)
  passwordHash String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artistProfile ArtistProfile?
  buyerProfile  BuyerProfile?
  adminProfile  AdminProfile?
  addresses     Address[]
  artworks      Artwork[]      @relation("ArtistArtworks")
  wishlistItems WishlistItem[]  @relation("BuyerWishlistItems")
  pricingRecommendations PricingRecommendation[] @relation("ArtistPricingRecommendations")
  impactEstimates ImpactEstimate[] @relation("ArtistImpactEstimates")
  decidedVerificationReviews VerificationReview[] @relation("VerificationDecider")
  verificationEvidenceUploads VerificationEvidenceAttachment[] @relation("VerificationEvidenceUploader")
  orders        Order[]        @relation("BuyerOrders")
  paymentTransactions PaymentTransaction[] @relation("BuyerPaymentTransactions")
  shipments     Shipment[]     @relation("BuyerShipments")
  payoutLedger  PayoutLedger[] @relation("ArtistPayoutLedger")
  notifications Notification[]
  notificationPreference NotificationPreference?
  auctionBids   AuctionBid[]   @relation("BidderAuctionBids")
  virtualRooms  VirtualRoomState[]
  analyticsEvents AnalyticsEvent[]
  returnRequests ReturnRequest[] @relation("BuyerReturnRequests")
  auditLogs     AuditLog[]     @relation("ActorAuditLogs")
  sessions      AuthSession[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  buyerCommissionRequests CommissionRequest[] @relation("BuyerCommissionRequests")
  assignedCommissionRequests CommissionRequest[] @relation("AssignedCommissionRequests")
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  deletedAt    DateTime?
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ArtistProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  firstName          String?
  lastName           String?
  phone              String?
  bio                String?
  location           String?
  website            String?
  instagram          String?
  twitter            String?
  facebook           String?
  verificationStatus String   @default("pending")
  specialties        String[] @default([])
  techniques         String[] @default([])
  preferredMaterials String[] @default([])
  yearsExperience    Int?
  payoutMethod       String?
  payoutAccountName  String?
  payoutAccountNumber String?
  payoutBankName     String?
  avatarUrl          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BuyerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  firstName            String?
  lastName             String?
  phone                String?
  avatarUrl            String?
  notifyOrderUpdates   Boolean  @default(true)
  notifyPromotions     Boolean  @default(false)
  notifyNewArtworks    Boolean  @default(true)
  notifyArtistUpdates  Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String?
  lastName  String?
  phone     String?
  title     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  seedKey       String?  @unique
  label         String
  recipientName String?
  phone         String?
  line1         String
  line2         String?
  city          String
  region        String?
  postalCode    String?
  country       String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, label])
}

model Artwork {
  id          String        @id @default(cuid())
  artistId    String
  slug        String        @unique
  title       String
  description String
  category    String
  ownerType   ArtworkOwnerType @default(artist)
  status      ArtworkStatus @default(draft)
  priceCents  Int
  currency    String        @default("RWF")
  dimensions  String?
  kgDiverted  Decimal       @default(0)
  viewCount   Int           @default(0)
  favouriteCount Int        @default(0)
  rejectionReason String?
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tags        String[]      @default([])
  theme       String?
  impactScore Int?
  artistLocation String?

  artist    User              @relation("ArtistArtworks", fields: [artistId], references: [id], onDelete: Restrict)
  images    ArtworkImage[]
  materials ArtworkMaterial[]
  wishlistItems WishlistItem[]
  pricingRecommendations PricingRecommendation[]
  impactEstimates ImpactEstimate[]
  verificationReview VerificationReview?
  verificationEvidence VerificationEvidenceAttachment[]
  orderItems OrderItem[]
  auctions Auction[]

  @@index([artistId])
  @@index([ownerType])
  @@index([status])
  @@index([createdAt])
}

model WishlistItem {
  id        String   @id @default(cuid())
  buyerId   String
  artworkId String
  createdAt DateTime @default(now())

  buyer   User    @relation("BuyerWishlistItems", fields: [buyerId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([buyerId, artworkId])
  @@index([buyerId])
  @@index([artworkId])
}

model ArtworkImage {
  id        String   @id @default(cuid())
  artworkId String
  url       String
  altText   String
  storageProvider String?
  storageKey String?
  uploadStatus MediaUploadStatus @default(uploaded)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId])
}

model ArtworkMaterial {
  id          String   @id @default(cuid())
  artworkId   String
  material    String
  weightKg    Decimal
  source      String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
}

model PricingRecommendation {
  id                 String   @id @default(cuid())
  artworkId          String
  artistId           String
  methodologyVersion String
  currency           String   @default("RWF")
  minCents           Int
  maxCents           Int
  suggestedCents     Int
  confidence         String
  explanation        String
  factors            Json
  input              Json
  createdAt          DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  artist  User    @relation("ArtistPricingRecommendations", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artworkId])
  @@index([artistId])
  @@index([createdAt])
}

model ImpactEstimate {
  id                             String   @id @default(cuid())
  artworkId                      String
  artistId                       String
  methodologyVersion             String
  kgDiverted                     Decimal
  co2eAvoidedKg                  Decimal
  landfillVolumeAvoidedLitres    Decimal
  confidence                     String
  assumptions                    String[] @default([])
  input                          Json
  result                         Json
  createdAt                      DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  artist  User    @relation("ArtistImpactEstimates", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artworkId])
  @@index([artistId])
  @@index([createdAt])
}

model VerificationReview {
  id                String                   @id @default(cuid())
  artworkId         String                   @unique
  status            VerificationReviewStatus @default(pending)
  recommendedAction String?
  reviewFlags       String[]                 @default([])
  adminNotes        String?
  artistMessage     String?
  decidedById       String?
  decidedAt         DateTime?
  requestedInfoAt   DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  artwork   Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  decidedBy User?   @relation("VerificationDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  evidence  VerificationEvidenceAttachment[]

  @@index([status])
  @@index([decidedById])
  @@index([createdAt])
}

model VerificationEvidenceAttachment {
  id         String                   @id @default(cuid())
  reviewId   String
  artworkId  String
  uploaderId String
  type       VerificationEvidenceType @default(other)
  url        String
  label      String
  notes      String?
  createdAt  DateTime                 @default(now())

  review   VerificationReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  artwork  Artwork            @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  uploader User               @relation("VerificationEvidenceUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([reviewId])
  @@index([artworkId])
  @@index([uploaderId])
  @@index([createdAt])
}

model Order {
  id                   String      @id @default(cuid())
  buyerId              String
  status               OrderStatus @default(pending_payment)
  currency             String      @default("RWF")
  paymentMethod        String      @default("momo")
  transactionReference String?     // MTN MoMo X-Reference-Id
  subtotalCents        Int
  deliveryCents        Int         @default(0)
  totalCents           Int
  deliveryAddress      Json
  notes                String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  buyer User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  items OrderItem[]
  payments PaymentTransaction[]
  shipment Shipment?
  payouts PayoutLedger[]
  returnRequests ReturnRequest[]

  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  artworkId  String
  artistId   String
  artistName String
  title      String
  artworkSlug String?
  ownerType  ArtworkOwnerType @default(artist)
  kgDiverted Decimal @default(0)
  unitCents  Int
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Restrict)
  payouts PayoutLedger[]

  @@index([orderId])
  @@index([artworkId])
  @@index([artistId])
}

model PaymentTransaction {
  id                    String          @id @default(cuid())
  orderId               String
  buyerId               String
  provider              PaymentProvider
  status                PaymentStatus   @default(pending)
  amountCents           Int
  currency              String          @default("RWF")
  providerReference     String?
  providerCheckoutUrl   String?
  momoPhone             String?
  ussdReference         String?
  idempotencyKey        String          @unique
  webhookEventId        String?         @unique
  rawProviderPayload    Json?
  failureReason         String?
  paidAt                DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer User  @relation("BuyerPaymentTransactions", fields: [buyerId], references: [id], onDelete: Restrict)
  refunds Refund[]

  @@index([orderId])
  @@index([buyerId])
  @@index([status])
  @@index([providerReference])
}

model Refund {
  id                   String        @id @default(cuid())
  paymentTransactionId String
  amountCents          Int
  reason               String
  status               PaymentStatus @default(pending)
  providerReference    String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@index([paymentTransactionId])
  @@index([status])
}

model Shipment {
  id                String         @id @default(cuid())
  orderId           String         @unique
  buyerId           String
  status            ShipmentStatus @default(pending)
  carrier           String?
  trackingNumber    String?
  deliveryAddress   Json
  deliveryFeeCents  Int            @default(0)
  artistPrepDueAt   DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer User  @relation("BuyerShipments", fields: [buyerId], references: [id], onDelete: Restrict)

  @@index([buyerId])
  @@index([status])
}

model PayoutLedger {
  id              String       @id @default(cuid())
  orderId         String
  orderItemId     String?
  artistId        String
  status          PayoutStatus @default(pending)
  grossCents      Int
  platformFeeCents Int
  deliveryCostCents Int @default(0)
  payoutCents     Int
  currency        String       @default("RWF")
  eligibleAt      DateTime
  approvedAt      DateTime?
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  providerReference String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  artist User @relation("ArtistPayoutLedger", fields: [artistId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([artistId])
  @@index([status])
  @@index([eligibleAt])
}

model ReturnRequest {
  id        String              @id @default(cuid())
  orderId   String
  buyerId   String
  reason    String
  status    ReturnRequestStatus @default(open)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer User  @relation("BuyerReturnRequests", fields: [buyerId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([buyerId])
  @@index([status])
}

model Notification {
  id           String              @id @default(cuid())
  userId       String
  channel      NotificationChannel
  status       NotificationStatus  @default(queued)
  templateKey  String
  subject      String?
  body         String
  metadata     Json?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  whatsappEnabled Boolean  @default(false)
  orderUpdates    Boolean  @default(true)
  moderation      Boolean  @default(true)
  auctions        Boolean  @default(true)
  marketing       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Auction {
  id                String        @id @default(cuid())
  artworkId         String
  status            AuctionStatus @default(draft)
  title             String
  startsAt          DateTime
  endsAt            DateTime
  startingBidCents  Int
  reserveCents      Int?
  minIncrementCents Int           @default(1000)
  currency          String        @default("RWF")
  winnerBidId       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Restrict)
  bids AuctionBid[]

  @@index([artworkId])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
}

model AuctionBid {
  id        String    @id @default(cuid())
  auctionId String
  bidderId  String
  amountCents Int
  status    BidStatus @default(active)
  createdAt DateTime  @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User    @relation("BidderAuctionBids", fields: [bidderId], references: [id], onDelete: Restrict)

  @@index([auctionId])
  @@index([bidderId])
  @@index([status])
  @@unique([auctionId, bidderId, amountCents])
}

model VirtualRoomState {
  id          String   @id @default(cuid())
  userId      String
  name        String
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique
  roomState   Json
  viewedArtworkIds String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  eventName   String
  entityType  String?
  entityId    String?
  metadata    Json?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventName])
  @@index([entityType, entityId])
  @@index([occurredAt])
}

model AnalyticsDailyAggregate {
  id         String   @id @default(cuid())
  date       DateTime
  metric     String
  entityType String?
  entityId   String?
  value      Int
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, metric, entityType, entityId])
  @@index([date])
  @@index([metric])
}

model SecurityEvent {
  id          String   @id @default(cuid())
  actorId     String?
  eventType   String
  severity    String
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

model CommissionRequest {
  id                 String                  @id @default(cuid())
  buyerId            String
  assignedArtistId   String?
  title              String
  description        String
  preferredMaterials String?
  budgetCents        Int
  currency           String                  @default("RWF")
  sizeCategory       CommissionSizeCategory
  dimensions         String?
  status             CommissionRequestStatus @default(submitted)
  adminNotes         String?
  artistResponseNote String?
  assignedAt         DateTime?
  respondedAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  buyer          User  @relation("BuyerCommissionRequests", fields: [buyerId], references: [id], onDelete: Restrict)
  assignedArtist User? @relation("AssignedCommissionRequests", fields: [assignedArtistId], references: [id], onDelete: SetNull)

  @@index([buyerId])
  @@index([assignedArtistId])
  @@index([status])
  @@index([createdAt])
}

model ContactMessage {
  id        String               @id @default(cuid())
  type      ContactMessageType
  status    ContactMessageStatus @default(unread)
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  metadata  Json?
  repliedAt DateTime?
  replyNote String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  seedKey   String?  @unique
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
}
